type Query {
    users: [UserDTO]
    user(id: ID!): UserDTO
    posts: [PostDTO]
    post(id: ID!): PostDTO
    searchPosts(keyword: String!): [PostDTO]
}

type Mutation {
    createUser(username: String!, email: String!, role: String!): UserDTO
    createPost(title: String!, content: String!, authorId: ID!): PostDTO
    addComment(content: String!, postId: ID!, authorId: ID!): CommentDTO
}

type UserDTO {
    id: ID
    username: String
    email: String
    role: String
}

type PostDTO {
    id: ID
    title: String
    content: String
    authorName: String
    createdAt: String
    views: Int
}

type CommentDTO {
    id: ID
    content: String
    authorName: String
    createdAt: String
}
